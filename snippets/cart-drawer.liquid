{% doc %}
  Renders reusable cart drawer markup for both initial page loads and Section Rendering API responses.

  FUUL design (Figma node 3:112): yellow header bar, free-shipping progress tracker,
  outlined item cards, pill quantity selector, summary + brown checkout pill.

  The presentation is FUUL-specific but the structure deliberately keeps the theme's
  live-cart contract intact so quantity changes and removals still work:
    - <theme-drawer id="cart-drawer"> / <dialog> — open/close, targeted by the header cart button
    - cart-items-component + data-section-id — Section Rendering API updates
    - ref="cartItemRows[]" + data-key — row lookup for update/remove
    - {% render 'quantity-selector' %} with line_index — ref="quantitySelectors[]"
    - on:click="/onLineItemRemove/N" — remove handler
    - #empty-cart-template — optimistic empty state

  @param {boolean} [render_wrapper] - When true, wraps the drawer in the section wrapper that the Section Rendering API adds automatically.
{% enddoc %}

{%- liquid
  assign render_wrapper = render_wrapper | default: true, allow_false: true

  # Free-shipping threshold in cents. Matches the "$65 Goal" label in the design.
  assign free_shipping_threshold = 6500
  assign remaining_for_free_shipping = free_shipping_threshold | minus: cart.total_price
  if remaining_for_free_shipping < 0
    assign remaining_for_free_shipping = 0
  endif
  assign shipping_progress = cart.total_price | times: 100.0 | divided_by: free_shipping_threshold
  if shipping_progress > 100
    assign shipping_progress = 100
  endif
-%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {% if render_wrapper %}
    <div
      id="shopify-section-cart-drawer-section"
      class="shopify-section"
    >
  {% endif %}

  {%- comment -%}
    cart-drawer.js drives the drawer; the other two power quantity edits and
    removals. cart-products.liquid used to load the latter two — this snippet
    no longer renders it, so they are requested here instead.
  {%- endcomment -%}
  <script
    type="module"
    src="{{ 'cart-drawer.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script
    type="module"
    src="{{ 'component-cart-items.js' | asset_url }}"
    fetchpriority="low"
  ></script>
  <script
    type="module"
    src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
    fetchpriority="low"
  ></script>

  {% capture empty_cart_drawer_content %}
    <div class="fuul-cart-drawer__empty">
      <p class="fuul-cart-drawer__empty-text">{{ 'content.your_cart_is_empty' | t }}</p>
      <a
        class="fuul-cart-drawer__empty-button"
        href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
      >
        {{ 'actions.continue_shopping' | t }}
      </a>
    </div>
  {% endcapture %}

  <theme-drawer
    id="cart-drawer"
    data-skip-node-update
  >
    <dialog
      ref="panel"
      class="theme-drawer__dialog fuul-cart-drawer"
      aria-labelledby="cart-drawer-heading"
      cart-summary-sticky="true"
    >
      <cart-drawer-component
        {% if settings.auto_open_cart_drawer and template.name != 'cart' %}
          auto-open
        {% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <div
          class="cart-drawer__inner fuul-cart-drawer__inner{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-hydration-key="cart-drawer-inner"
        >
          {%- comment -%} ---------- yellow header ---------- {%- endcomment -%}
          <div class="fuul-cart-drawer__header">
            <h2
              class="fuul-cart-drawer__title"
              id="cart-drawer-heading"
            >
              Your Cart
            </h2>
            <button
              class="fuul-cart-drawer__close"
              on:click="#cart-drawer/close"
              type="button"
              aria-label="{{ 'actions.close' | t }}"
            >
              <span class="fuul-cart-drawer__close-icon">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          {% capture cart_items_children %}
            {%- if cart.empty? -%}
              {{ empty_cart_drawer_content }}
            {%- else -%}
              {%- comment -%} ---------- free shipping progress ---------- {%- endcomment -%}
              <div class="fuul-cart-drawer__progress">
                <p class="fuul-cart-drawer__progress-text">
                  {%- if remaining_for_free_shipping > 0 -%}
                    You're
                    <strong>{{ remaining_for_free_shipping | money }}</strong>
                    away from FREE shipping!
                  {%- else -%}
                    <strong>You've unlocked FREE shipping!</strong>
                  {%- endif -%}
                </p>
                <div class="fuul-cart-drawer__progress-track">
                  <div
                    class="fuul-cart-drawer__progress-fill"
                    style="width: {{ shipping_progress }}%;"
                  ></div>
                </div>
                <div class="fuul-cart-drawer__progress-labels">
                  <span>{{ 0 | money }}</span>
                  <span class="fuul-cart-drawer__progress-goal">{{ free_shipping_threshold | money }} Goal</span>
                </div>
              </div>

              {%- comment -%} ---------- line items ---------- {%- endcomment -%}
              <div class="fuul-cart-drawer__items">
                <span
                  class="visually-hidden"
                  ref="cartItemCount"
                  aria-hidden="true"
                >
                  {{- cart.item_count -}}
                </span>

                <form
                  action="{{ routes.cart_url }}"
                  class="cart-form fuul-cart-drawer__form"
                  id="cart-form"
                  method="post"
                >
                  {%- for item in cart.items -%}
                    {%- liquid
                      assign line = item.index | plus: 1
                      assign can_remove = item.instructions.can_remove | default: true, allow_false: true
                      assign can_update_quantity = item.instructions.can_update_quantity | default: true, allow_false: true
                    -%}
                    <div
                      id="CartItem-{{ item.key }}"
                      class="fuul-cart-drawer__item{% if item.parent_relationship.parent != null %} fuul-cart-drawer__item--nested{% endif %}"
                      ref="cartItemRows[]"
                      data-parent-key="{{ item.parent_relationship.parent.key }}"
                      data-key="{{ item.key }}"
                    >
                      <a
                        class="fuul-cart-drawer__item-media"
                        href="{{ item.url }}"
                        tabindex="-1"
                        aria-hidden="true"
                      >
                        {%- if item.image -%}
                          {{
                            item.image
                            | image_url: width: 240
                            | image_tag: widths: '80,160,240', alt: '', loading: 'lazy'
                          }}
                        {%- endif -%}
                      </a>

                      <div class="fuul-cart-drawer__item-details">
                        <a
                          class="fuul-cart-drawer__item-title"
                          href="{{ item.url }}"
                        >
                          {{- item.product.title -}}
                        </a>

                        <p class="fuul-cart-drawer__item-meta">
                          {%- unless item.variant.title contains 'Default' -%}
                            {{ item.variant.title }} •
                          {%- endunless -%}
                          {{ item.quantity }}
                          {%- if item.quantity == 1 %} item{% else %} items{% endif -%}
                        </p>

                        <div class="fuul-cart-drawer__item-row">
                          <div class="fuul-cart-drawer__item-price">
                            <span class="fuul-cart-drawer__price">{{ item.final_line_price | money }}</span>
                            {%- if item.original_line_price > item.final_line_price -%}
                              <s class="fuul-cart-drawer__price-compare">{{ item.original_line_price | money }}</s>
                            {%- endif -%}
                          </div>

                          {% render 'quantity-selector',
                            product: item.product,
                            variant: item.variant,
                            in_cart_quantity: item.quantity,
                            line_index: item.index,
                            can_update_quantity: can_update_quantity
                          %}
                        </div>

                        {%- if can_remove -%}
                          <button
                            type="button"
                            class="fuul-cart-drawer__remove"
                            aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                            on:click="/onLineItemRemove/{{ line }}"
                          >
                            <span class="fuul-cart-drawer__remove-icon">
                              {{- 'icon-delete.svg' | inline_asset_content -}}
                            </span>
                            {{ 'actions.remove' | t }}
                          </button>
                        {%- endif -%}

                        <div
                          class="fuul-cart-drawer__item-error"
                          ref="cartItemErrorContainer-{{ line }}"
                          hidden
                        >
                          <span ref="cartItemError-{{ line }}"></span>
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                </form>
              </div>

              {%- comment -%} ---------- summary + checkout ---------- {%- endcomment -%}
              <div class="fuul-cart-drawer__footer">
                <div class="fuul-cart-drawer__summary">
                  <div class="fuul-cart-drawer__summary-row">
                    <span>{{ 'content.cart_subtotal' | t }}</span>
                    <span class="fuul-cart-drawer__summary-value">{{ cart.total_price | money }}</span>
                  </div>
                  <div class="fuul-cart-drawer__summary-row">
                    <span>Shipping</span>
                    <span class="fuul-cart-drawer__summary-note">Calculated at checkout</span>
                  </div>
                  <div class="fuul-cart-drawer__summary-divider"></div>
                  <div class="fuul-cart-drawer__summary-row fuul-cart-drawer__summary-row--total">
                    <span>Estimated Total</span>
                    <span class="fuul-cart-drawer__summary-value">{{ cart.total_price | money }}</span>
                  </div>
                </div>

                <button
                  type="submit"
                  id="checkout"
                  class="fuul-cart-drawer__checkout"
                  name="checkout"
                  form="cart-form"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                >
                  Checkout • {{ cart.total_price | money }}
                </button>

                <button
                  type="button"
                  class="fuul-cart-drawer__continue"
                  on:click="#cart-drawer/close"
                >
                  or Continue Shopping
                </button>
              </div>
            {%- endif -%}
          {% endcapture %}
          {% render 'cart-items-component',
            children: cart_items_children,
            is_drawer: true,
            section_id: 'cart-drawer-section'
          %}
        </div>
      </cart-drawer-component>
    </dialog>
  </theme-drawer>

  {% if render_wrapper %}
    </div>
  {% endif %}
{%- endif -%}

{% stylesheet %}
  cart-drawer-component {
    display: contents;
  }

  .fuul-cart-drawer {
    --fuul-brown: #60413f;
    --fuul-gold: #f7c638;
    --fuul-green: #8cb90e;
    --fuul-green-soft: #ecf2db;
    --fuul-muted: #907a79;
    --theme-drawer-width: 420px;

    /* Surfaces follow the palette selected in theme settings
       (:root --color-* from snippets/color-palette.liquid), so the drawer
       matches the rest of the store instead of being hardcoded white.
       FUUL brand values are the fallbacks when no palette is set. */
    --fuul-cart-drawer-surface: var(--color-background, #fff);
    --fuul-cart-drawer-text: var(--color-foreground, #60413f);
    --fuul-cart-drawer-line: var(--color-border, #60413f);

    background: var(--fuul-cart-drawer-surface);
    color: var(--fuul-cart-drawer-text);
    font-family: 'Dongle', ui-rounded, 'Trebuchet MS', sans-serif;
  }

  .fuul-cart-drawer *,
  .fuul-cart-drawer *::before,
  .fuul-cart-drawer *::after {
    box-sizing: border-box;
  }

  .fuul-cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .fuul-cart-drawer__inner > .cart-items-component {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  /* ---------- header ---------- */
  .fuul-cart-drawer__header {
    flex: none;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    height: 60px;
    padding: 0 24px;
    background: var(--fuul-gold);
  }

  .fuul-cart-drawer__title {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-weight: 600;
    font-size: 28px;
    line-height: 1.1;
    color: var(--fuul-brown);
  }

  .fuul-cart-drawer__close {
    flex: none;
    width: 32px;
    height: 32px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: var(--fuul-brown);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .fuul-cart-drawer__close-icon {
    display: block;
    width: 16px;
    height: 16px;
  }

  .fuul-cart-drawer__close-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ---------- free shipping progress ---------- */
  .fuul-cart-drawer__progress {
    flex: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px 24px;
    border-bottom: 2px solid var(--fuul-gold);
  }

  .fuul-cart-drawer__progress-text {
    margin: 0;
    font-size: 22px;
    line-height: 0.9;
  }

  .fuul-cart-drawer__progress-text strong {
    font-weight: 700;
    color: var(--fuul-green);
  }

  .fuul-cart-drawer__progress-track {
    height: 16px;
    border-radius: 8px;
    background: var(--fuul-green-soft);
    overflow: hidden;
  }

  .fuul-cart-drawer__progress-fill {
    height: 100%;
    border-radius: 8px;
    background: var(--fuul-green);
    transition: width 0.3s ease;
  }

  .fuul-cart-drawer__progress-labels {
    display: flex;
    justify-content: space-between;
    font-size: 18px;
    line-height: 0.8;
  }

  .fuul-cart-drawer__progress-goal {
    font-weight: 700;
  }

  /* ---------- items ---------- */
  .fuul-cart-drawer__items {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 20px 24px;
  }

  .fuul-cart-drawer__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
  }

  .fuul-cart-drawer__item {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 2px solid var(--fuul-cart-drawer-line);
    border-radius: 14px;
    background: var(--fuul-cart-drawer-surface);
    color: var(--fuul-cart-drawer-text);
  }

  .fuul-cart-drawer__item-media {
    flex: none;
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    /* Faint tint of the current text color rather than a fixed grey, so the
       thumbnail placeholder stays visible on light and dark palettes alike. */
    background: rgb(var(--color-foreground-rgb, 96 65 63) / 6%);
    display: block;
  }

  .fuul-cart-drawer__item-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fuul-cart-drawer__item-details {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fuul-cart-drawer__item-title {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-weight: 600;
    font-size: 18px;
    line-height: 1.2;
    color: var(--fuul-cart-drawer-text);
    text-decoration: none;
  }

  .fuul-cart-drawer__item-meta {
    margin: 0;
    font-size: 18px;
    line-height: 0.9;
    opacity: 0.8;
  }

  .fuul-cart-drawer__item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .fuul-cart-drawer__item-price {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fuul-cart-drawer__price {
    font-weight: 700;
    font-size: 24px;
    line-height: 0.8;
  }

  .fuul-cart-drawer__price-compare {
    font-weight: 300;
    font-size: 18px;
    line-height: 0.8;
    color: rgb(var(--color-foreground-rgb, 144 122 121) / 65%);
  }

  /* pill quantity selector — overrides the shared quantity-selector styles */
  .fuul-cart-drawer .quantity-selector-wrapper {
    flex: none;
    gap: 0;
  }

  .fuul-cart-drawer .quantity-selector {
    display: flex;
    align-items: center;
    gap: 12px;
    width: auto;
    min-height: 0;
    padding: 4px 8px;
    border: 2px solid var(--fuul-cart-drawer-line);
    border-radius: 100px;
    background: transparent;
  }

  .fuul-cart-drawer .quantity-selector button {
    width: 20px;
    height: 20px;
    min-width: 0;
    min-height: 0;
    padding: 0;
    border: 0;
    background: none;
    color: var(--fuul-cart-drawer-text);
    cursor: pointer;
  }

  .fuul-cart-drawer .quantity-selector button svg {
    width: 12px;
    height: 12px;
  }

  .fuul-cart-drawer .quantity-selector button[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .fuul-cart-drawer .quantity-selector input {
    width: 24px;
    max-width: none;
    min-height: 0;
    padding: 0;
    border: 0;
    background: none;
    color: var(--fuul-cart-drawer-text);
    font-family: inherit;
    font-weight: 700;
    font-size: 26px;
    line-height: 0.8;
    text-align: center;
    -moz-appearance: textfield;
  }

  .fuul-cart-drawer .quantity-selector input::-webkit-outer-spin-button,
  .fuul-cart-drawer .quantity-selector input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .fuul-cart-drawer__remove {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    padding: 0;
    border: 0;
    background: none;
    color: var(--fuul-cart-drawer-text);
    font-family: inherit;
    font-size: 18px;
    line-height: 0.8;
    text-decoration: underline;
    cursor: pointer;
  }

  .fuul-cart-drawer__remove-icon {
    display: block;
    width: 12px;
    height: 12px;
  }

  .fuul-cart-drawer__remove-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .fuul-cart-drawer__item-error {
    font-size: 16px;
    color: #c0392b;
  }

  .fuul-cart-drawer__item-error[hidden] {
    display: none;
  }

  /* row removal animation (previously supplied by cart-products.liquid) */
  .fuul-cart-drawer__item.removing {
    overflow: hidden;
    animation: fuulRemoveRow 0.3s ease forwards;
  }

  @keyframes fuulRemoveRow {
    to {
      height: 0;
      min-height: 0;
      padding-block: 0;
      border-width: 0;
      opacity: 0;
      margin-block: calc(-1 * var(--row-height, 0px) / 8);
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .fuul-cart-drawer__item.removing {
      animation: none;
    }
  }

  /* ---------- footer ---------- */
  .fuul-cart-drawer__footer {
    flex: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 16px 24px 24px;
    background: var(--fuul-cart-drawer-surface);
    border-top: 1px solid rgb(var(--color-foreground-rgb, 96 65 63) / 15%);
  }

  .fuul-cart-drawer__summary {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .fuul-cart-drawer__summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 24px;
    line-height: 0.8;
  }

  .fuul-cart-drawer__summary-value {
    font-weight: 700;
    font-size: 26px;
  }

  .fuul-cart-drawer__summary-note {
    font-size: 18px;
    opacity: 0.7;
  }

  .fuul-cart-drawer__summary-divider {
    height: 1px;
    background: rgb(var(--color-foreground-rgb, 96 65 63) / 20%);
  }

  .fuul-cart-drawer__summary-row--total {
    font-size: 26px;
  }

  .fuul-cart-drawer__summary-row--total .fuul-cart-drawer__summary-value {
    font-size: 32px;
  }

  .fuul-cart-drawer__checkout {
    height: 60px;
    padding: 0 16px;
    border: 0;
    border-radius: 100px;
    background: var(--fuul-brown);
    color: #fff;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-weight: 600;
    font-size: 22px;
    line-height: 1.1;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  .fuul-cart-drawer__checkout:hover {
    filter: brightness(1.1);
  }

  .fuul-cart-drawer__checkout[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .fuul-cart-drawer__continue {
    padding: 0;
    border: 0;
    background: none;
    color: var(--fuul-cart-drawer-text);
    font-family: inherit;
    font-size: 24px;
    line-height: 0.8;
    text-align: center;
    text-decoration: underline;
    cursor: pointer;
  }

  /* ---------- empty state ---------- */
  .fuul-cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 40px 24px;
    text-align: center;
  }

  .fuul-cart-drawer__empty-text {
    margin: 0;
    font-size: 32px;
    line-height: 0.9;
  }

  .fuul-cart-drawer__empty-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 56px;
    padding: 0 28px;
    border-radius: 100px;
    background: var(--fuul-brown);
    color: #fff;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-weight: 600;
    font-size: 20px;
    text-decoration: none;
  }

  /* ---------- responsive ---------- */
  @media screen and (max-width: 749px) {
    .fuul-cart-drawer {
      --theme-drawer-width: 100%;
    }

    .fuul-cart-drawer__header,
    .fuul-cart-drawer__progress {
      padding-inline: 16px;
    }

    .fuul-cart-drawer__items {
      padding: 16px;
    }

    .fuul-cart-drawer__footer {
      padding: 16px 16px 20px;
    }
  }
{% endstylesheet %}
