{%- comment -%}
  FUUL Product Detail Page — faithful reproduction of the Figma design.
  Chrome (announcement/header/cart-drawer) is intentionally left to the theme.

  Copy (labels, badges, perks, accordions) is exposed via schema settings.
  Prices are NOT — every figure shown is read from the product in Shopify:
  variant price, compare-at price, volume pricing (quantity price breaks) and
  selling plan allocations. See the pricing block below.

  Add-to-cart is wired to the real product form so the theme cart drawer opens
  on submit.
{%- endcomment -%}

{%- comment -%} Dongle + Fraunces are loaded once in <head> via snippets/fuul-fonts.liquid {%- endcomment -%}

{%- liquid
  assign product = section.settings.product | default: product
  assign variant = product.selected_or_first_available_variant
  assign can_add = false
  if variant.available
    assign can_add = true
  endif

  assign uses_selling_plans = false
  if product.selling_plan_groups.size > 0
    assign uses_selling_plans = true
    assign first_plan = product.selling_plan_groups.first.selling_plans.first
  endif

  assign form_id = 'fuul-product-form-' | append: section.id

  # ---------------------------------------------------------------------------
  # Pricing — all values below come from Shopify, never from theme settings.
  #
  # Every bundle adds the SAME variant at a different quantity, so the honest
  # per-tier price is Shopify's own volume pricing (quantity_price_breaks).
  # Those are real prices that checkout honours. When a merchant has not
  # configured volume pricing the tiers simply fall back to unit price x qty,
  # which is exactly what the customer will be charged.
  # ---------------------------------------------------------------------------
  assign b1_qty = section.settings.b1_quantity | default: 1
  assign b2_qty = section.settings.b2_quantity | default: 2
  assign b3_qty = section.settings.b3_quantity | default: 4

  assign unit_price = variant.price

  # "List" unit price for strike-throughs: the variant's compare-at when it is
  # genuinely higher, otherwise its own price (which yields no strike-through).
  # Guarded the way snippets/price.liquid does it, so a nil compare-at is safe.
  assign unit_list = unit_price
  if variant.compare_at_price > unit_price
    assign unit_list = variant.compare_at_price
  endif

  # Best volume-price break each tier qualifies for.
  assign b1_unit = unit_price
  assign b2_unit = unit_price
  assign b3_unit = unit_price
  for price_break in variant.quantity_price_breaks
    if b1_qty >= price_break.minimum_quantity and price_break.price < b1_unit
      assign b1_unit = price_break.price
    endif
    if b2_qty >= price_break.minimum_quantity and price_break.price < b2_unit
      assign b2_unit = price_break.price
    endif
    if b3_qty >= price_break.minimum_quantity and price_break.price < b3_unit
      assign b3_unit = price_break.price
    endif
  endfor

  assign b1_total = b1_unit | times: b1_qty
  assign b2_total = b2_unit | times: b2_qty
  assign b3_total = b3_unit | times: b3_qty

  assign b1_list = unit_list | times: b1_qty
  assign b2_list = unit_list | times: b2_qty
  assign b3_list = unit_list | times: b3_qty

  assign b1_save_pct = 0
  if b1_list > b1_total
    assign b1_save_pct = b1_list | minus: b1_total | times: 100 | divided_by: b1_list
  endif
  assign b2_save_pct = 0
  if b2_list > b2_total
    assign b2_save_pct = b2_list | minus: b2_total | times: 100 | divided_by: b2_list
  endif
  assign b3_save_pct = 0
  if b3_list > b3_total
    assign b3_save_pct = b3_list | minus: b3_total | times: 100 | divided_by: b3_list
  endif

  # Per-serving price for the best-value tier.
  assign servings_per_unit = section.settings.servings_per_unit | default: 0
  assign b3_servings = servings_per_unit | times: b3_qty
  assign b3_has_serving = false
  if b3_servings > 0
    assign b3_serving_price = b3_total | divided_by: b3_servings
    assign b3_has_serving = true
  endif

  # Subscription pricing from the real selling plan allocation.
  assign plan_unit = unit_price
  assign plan_unit_compare = unit_price
  if uses_selling_plans
    for allocation in variant.selling_plan_allocations
      if allocation.selling_plan_id == first_plan.id
        assign plan_unit = allocation.price
        assign plan_unit_compare = allocation.compare_at_price | default: unit_price
      endif
    endfor
  endif
  assign plan_save_pct = 0
  if plan_unit_compare > plan_unit
    assign plan_save_pct = plan_unit_compare | minus: plan_unit | times: 100 | divided_by: plan_unit_compare
  endif
-%}

<section class="fuul-pdp color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="fuul-pdp__inner">

    {%- comment -%} ============ GALLERY ============ {%- endcomment -%}
    <div class="fuul-gallery" data-fuul-gallery>
      {%- if product.media.size > 0 -%}
        <div class="fuul-gallery__thumbs" data-fuul-scroll-container>
          {%- for media in product.media -%}
            <button
              type="button"
              class="fuul-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-fuul-thumb
              data-src="{{ media.preview_image | image_url: width: 1200 }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ media.preview_image | image_url: width: 200 }}"
                alt="{{ media.alt | escape }}"
                width="100"
                height="100"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
          {%- if product.media.size > 4 -%}
            <div class="fuul-gallery__scroll-hint" aria-hidden="true">→</div>
          {%- endif -%}
        </div>
        <div class="fuul-gallery__main">
          <img
            data-fuul-main
            src="{{ product.featured_media.preview_image | image_url: width: 1200 }}"
            alt="{{ product.featured_media.alt | escape }}"
            width="600"
            height="600"
          >
        </div>
      {%- else -%}
        {%- assign fallback = 'fuul-bundle-1.png,fuul-bundle-2.png,fuul-bundle-4.png' | split: ',' -%}
        <div class="fuul-gallery__thumbs" data-fuul-scroll-container>
          {%- for img in fallback -%}
            <button
              type="button"
              class="fuul-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-fuul-thumb
              data-src="{{ img | asset_url }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ img | asset_url }}" alt="" width="100" height="100" loading="lazy">
            </button>
          {%- endfor -%}
          <div class="fuul-gallery__scroll-hint" aria-hidden="true">→</div>
        </div>
        <div class="fuul-gallery__main">
          <img data-fuul-main src="{{ 'fuul-bundle-1.png' | asset_url }}" alt="{{ product.title | escape }}" width="600" height="600">
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ============ INFO COLUMN ============ {%- endcomment -%}
    <div class="fuul-info">

      {%- comment -%} rating + title + subtitle {%- endcomment -%}
      <div class="fuul-head">
        <div class="fuul-rating">
          <img src="{{ 'fuul-stars.svg' | asset_url }}" alt="5 out of 5 stars" width="82" height="14">
          <span class="fuul-rating__text">{{ section.settings.rating_text }}</span>
        </div>
        <h1 class="fuul-title">{{ product.title | default: 'FUUL Protein Cookie Dough Bites - Chocolate Chip' }}</h1>
        <p class="fuul-subtitle">{{ section.settings.subtitle }}</p>
      </div>

      {%- comment -%} feature checklist {%- endcomment -%}
      {%- assign features = section.settings.features | newline_to_br | split: '<br />' -%}
      <ul class="fuul-features">
        {%- for feature in features -%}
          {%- assign f = feature | strip -%}
          {%- if f != blank -%}
            <li class="fuul-features__item">
              <img src="{{ 'fuul-check.svg' | asset_url }}" alt="" width="32" height="32">
              <span>{{ f }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <hr class="fuul-divider">

      {%- comment -%} ============ BUNDLE SELECTOR ============ {%- endcomment -%}
      <h2 class="fuul-section-title">{{ section.settings.bundle_heading }}</h2>
      <div class="fuul-bundles" role="radiogroup" aria-label="{{ section.settings.bundle_heading | escape }}">

        {%- comment -%} bundle 1 {%- endcomment -%}
        <label class="fuul-bundle" data-fuul-bundle data-quantity="{{ b1_qty }}">
          <input type="radio" name="fuul-bundle" value="{{ b1_qty }}" hidden>
          <span class="fuul-bundle__label">{{ section.settings.b1_label }}</span>
          <span class="fuul-bundle__line"></span>
          {%- if b1_save_pct > 0 -%}
            <span class="fuul-pill fuul-pill--cream">Save {{ b1_save_pct }}%</span>
          {%- endif -%}
          <img class="fuul-bundle__img" src="{{ 'fuul-bundle-1.png' | asset_url }}" alt="" width="120" height="120" loading="lazy">
          <span class="fuul-bundle__price">{{ b1_total | money }}</span>
          {%- if b1_list > b1_total -%}
            <span class="fuul-bundle__compare">{{ b1_list | money }}</span>
          {%- endif -%}
        </label>

        {%- comment -%} bundle 2 (Most Popular, default) {%- endcomment -%}
        <label class="fuul-bundle fuul-bundle--popular is-selected" data-fuul-bundle data-quantity="{{ b2_qty }}">
          <span class="fuul-bundle__badge fuul-bundle__badge--popular">{{ section.settings.b2_badge }}</span>
          <input type="radio" name="fuul-bundle" value="{{ b2_qty }}" checked hidden>
          <span class="fuul-bundle__label">{{ section.settings.b2_label }}</span>
          <span class="fuul-bundle__line"></span>
          {%- if b2_save_pct > 0 -%}
            <span class="fuul-pill fuul-pill--cream">Save {{ b2_save_pct }}%</span>
          {%- endif -%}
          <img class="fuul-bundle__img" src="{{ 'fuul-bundle-2.png' | asset_url }}" alt="" width="120" height="120" loading="lazy">
          <span class="fuul-bundle__price">{{ b2_total | money }}</span>
          {%- if b2_list > b2_total -%}
            <span class="fuul-bundle__compare">{{ b2_list | money }}</span>
          {%- endif -%}
        </label>

        {%- comment -%} bundle 4 (Best Value) {%- endcomment -%}
        <label class="fuul-bundle fuul-bundle--value" data-fuul-bundle data-quantity="{{ b3_qty }}">
          <span class="fuul-bundle__badge fuul-bundle__badge--value">{{ section.settings.b3_badge }}</span>
          <input type="radio" name="fuul-bundle" value="{{ b3_qty }}" hidden>
          <span class="fuul-bundle__label">{{ section.settings.b3_label }}</span>
          <span class="fuul-bundle__line"></span>
          <span class="fuul-bundle__sub">{{ section.settings.b3_sublabel }}</span>
          {%- if b3_save_pct > 0 -%}
            <span class="fuul-pill fuul-pill--cream">Save {{ b3_save_pct }}%</span>
          {%- endif -%}
          <img class="fuul-bundle__img" src="{{ 'fuul-bundle-4.png' | asset_url }}" alt="" width="120" height="120" loading="lazy">
          <div class="fuul-bundle__price-group">
            <span class="fuul-bundle__price">{{ b3_total | money }}</span>
            {%- if b3_has_serving -%}
              <span class="fuul-bundle__serving">
                <img src="{{ 'fuul-leaf.svg' | asset_url }}" alt="" width="13" height="13">
                {{ b3_serving_price | money }} {{ section.settings.serving_suffix }}
              </span>
            {%- endif -%}
          </div>
        </label>
      </div>

      {%- comment -%} ============ AUTOSHIP ============ {%- endcomment -%}
      <h2 class="fuul-section-title">{{ section.settings.autoship_heading }}</h2>
      <div class="fuul-plans" role="radiogroup" aria-label="{{ section.settings.autoship_heading | escape }}">

        {%- comment -%} Subscribe & Save (default) {%- endcomment -%}
        <label class="fuul-plan fuul-plan--sub is-selected" data-fuul-plan data-selling-plan="{{ first_plan.id }}">
          <input type="radio" name="fuul-plan" value="subscribe" checked hidden>
          <div class="fuul-plan__top">
            <span class="fuul-radio" aria-hidden="true"></span>
            <div class="fuul-plan__info">
              <span class="fuul-plan__name">{{ section.settings.sub_title }}</span>
              {%- comment -%}
                Cadence comes from the selling plan itself (e.g. "Delivery every
                12 weeks"), so it always matches what Shopify will bill.
              {%- endcomment -%}
              <span class="fuul-plan__meta">
                {{- first_plan.name | default: section.settings.sub_billing -}}
              </span>
            </div>
            {%- if plan_save_pct > 0 -%}
              <span class="fuul-pill fuul-pill--gold">Save {{ plan_save_pct }}%</span>
            {%- endif -%}
            <div class="fuul-plan__price">
              <span
                class="fuul-plan__now"
                data-fuul-plan-price
                data-price-{{ b1_qty }}="{{ plan_unit | times: b1_qty | money }}"
                data-price-{{ b2_qty }}="{{ plan_unit | times: b2_qty | money }}"
                data-price-{{ b3_qty }}="{{ plan_unit | times: b3_qty | money }}"
              >
                {{- plan_unit | times: b2_qty | money -}}
              </span>
              {%- if plan_unit_compare > plan_unit -%}
                <span
                  class="fuul-plan__was"
                  data-fuul-plan-compare
                  data-price-{{ b1_qty }}="{{ plan_unit_compare | times: b1_qty | money }}"
                  data-price-{{ b2_qty }}="{{ plan_unit_compare | times: b2_qty | money }}"
                  data-price-{{ b3_qty }}="{{ plan_unit_compare | times: b3_qty | money }}"
                >
                  {{- plan_unit_compare | times: b2_qty | money -}}
                </span>
              {%- endif -%}
            </div>
          </div>
          <hr class="fuul-plan__rule">
          <ul class="fuul-plan__perks">
            {%- assign perks = section.settings.sub_perks | newline_to_br | split: '<br />' -%}
            {%- for perk in perks -%}
              {%- assign p = perk | strip -%}
              {%- if p != blank -%}
                <li><img src="{{ 'fuul-check-sm.svg' | asset_url }}" alt="" width="14" height="9">{{ p }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </label>

        {%- comment -%} One time {%- endcomment -%}
        <label class="fuul-plan fuul-plan--once" data-fuul-plan data-selling-plan="">
          <input type="radio" name="fuul-plan" value="once" hidden>
          <div class="fuul-plan__top">
            <span class="fuul-radio" aria-hidden="true"></span>
            <div class="fuul-plan__info">
              <span class="fuul-plan__name">{{ section.settings.once_title }}</span>
              <span class="fuul-plan__meta">{{ section.settings.once_billing }}</span>
            </div>
            <div class="fuul-plan__price">
              <span
                class="fuul-plan__now"
                data-fuul-once-price
                data-price-{{ b1_qty }}="{{ b1_total | money }}"
                data-price-{{ b2_qty }}="{{ b2_total | money }}"
                data-price-{{ b3_qty }}="{{ b3_total | money }}"
              >
                {{- b2_total | money -}}
              </span>
            </div>
          </div>
          <hr class="fuul-plan__rule">
          <ul class="fuul-plan__perks fuul-plan__perks--muted">
            {%- assign nos = section.settings.once_perks | newline_to_br | split: '<br />' -%}
            {%- for no in nos -%}
              {%- assign n = no | strip -%}
              {%- if n != blank -%}
                <li><img src="{{ 'fuul-x-sm.svg' | asset_url }}" alt="" width="13" height="13">{{ n }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </label>
      </div>

      {%- comment -%} ============ ADD TO CART ============ {%- endcomment -%}
      <product-form-component
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
        on:submit="/handleSubmit"
        class="fuul-form"
      >
        <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
        {%- form 'product', product, id: form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" ref="variantId" value="{{ variant.id }}" data-fuul-variant {% unless variant.available %}disabled{% endunless %}>
          <input type="hidden" name="quantity" value="{{ b2_qty }}" data-fuul-quantity>
          <input type="hidden" name="selling_plan" value="{{ first_plan.id }}" data-fuul-selling-plan>

          <add-to-cart-component
            ref="addToCartButtonContainer"
            data-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
          >
            <button
              type="submit"
              name="add"
              ref="addToCartButton"
              on:click="/handleClick"
              class="button fuul-cta"
              {% unless can_add %}disabled{% endunless %}
            >
              <span class="fuul-cta__text">{{ section.settings.cta_text }}</span>
              <span class="add-to-cart__added">
                <span class="svg-wrapper add-to-cart__added-icon">
                  {{- 'icon-checkmark-burst.svg' | inline_asset_content -}}
                </span>
              </span>
            </button>
          </add-to-cart-component>
        {%- endform -%}
      </product-form-component>

      {%- if section.settings.promo_bar != blank -%}
        <div class="fuul-promo">{{ section.settings.promo_bar }}</div>
      {%- endif -%}

      {%- comment -%} ============ TRUST BADGES ============ {%- endcomment -%}
      <div class="fuul-trust">
        <div class="fuul-trust__item">
          <img src="{{ 'fuul-badge-ships.svg' | asset_url }}" alt="" width="52" height="52">
          <span>{{ section.settings.trust1 }}</span>
        </div>
        <div class="fuul-trust__item">
          <img src="{{ 'fuul-badge-freeship.svg' | asset_url }}" alt="" width="52" height="52">
          <span>{{ section.settings.trust2 }}</span>
        </div>
        <div class="fuul-trust__item">
          <img src="{{ 'fuul-badge-secure.svg' | asset_url }}" alt="" width="52" height="52">
          <span>{{ section.settings.trust3 }}</span>
        </div>
      </div>

      {%- comment -%} ============ ACCORDIONS ============ {%- endcomment -%}
      <div class="fuul-accordions">
        {%- for i in (1..3) -%}
          {%- assign heading_key = 'acc' | append: i | append: '_heading' -%}
          {%- assign body_key = 'acc' | append: i | append: '_body' -%}
          {%- assign acc_heading = section.settings[heading_key] -%}
          {%- assign acc_body = section.settings[body_key] -%}
          {%- if acc_heading != blank -%}
            <details class="fuul-acc">
              <summary class="fuul-acc__summary">
                <span class="fuul-acc__title">{{ acc_heading }}</span>
                <span class="fuul-acc__icon" aria-hidden="true">
                  <img src="{{ 'fuul-caret.svg' | asset_url }}" alt="" width="13" height="13">
                </span>
              </summary>
              <div class="fuul-acc__body">{{ acc_body }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
.fuul-pdp {
  --fuul-brown: #60413f;
  --fuul-brown-muted: #907a79;
  --fuul-yellow: #ffcb00;
  --fuul-gold: #f7c638;
  --fuul-yellow-soft: #fff2c6;
  --fuul-cream: #f7eeda;
  --fuul-green: #8cb90e;
  --fuul-green-dark: #306c00;
  --fuul-green-soft: #ecf2db;
  --fuul-serif: 'Fraunces', 'Times New Roman', serif;
  --fuul-sans: 'Dongle', ui-rounded, 'Trebuchet MS', sans-serif;
  color: var(--fuul-brown);
  font-family: var(--fuul-sans);
}
.fuul-pdp *, .fuul-pdp *::before, .fuul-pdp *::after { box-sizing: border-box; }

.fuul-pdp__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 52px 40px 80px;
  display: grid;
  grid-template-columns: minmax(0, 724px) 593px;
  gap: 43px;
  align-items: start;
}

/* ---------- GALLERY ---------- */
.fuul-gallery {
  position: sticky;
  top: 24px;
  display: grid;
  grid-template-columns: 100px minmax(0, 1fr);
  gap: 24px;
}
.fuul-gallery__thumbs {
  display: flex; flex-direction: column; gap: 14px;
  /* On desktop, when many images, show vertical scroll hint */
  position: relative;
}
.fuul-gallery__thumbs[data-fuul-scroll-container] {
  /* Reserve space for scroll indicator */
  padding: 0;
}
.fuul-gallery__thumb {
  padding: 0; border: 2px solid transparent; background: #f4f4f4;
  border-radius: 12px; overflow: hidden; cursor: pointer; aspect-ratio: 1;
  transition: border-color .15s ease; flex: none;
}
.fuul-gallery__thumb.is-active { border-color: var(--fuul-brown); }
.fuul-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.fuul-gallery__main {
  background: #f4f4f4; border-radius: 20px; overflow: hidden; aspect-ratio: 1;
}
.fuul-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Scroll hint indicator on mobile */
.fuul-gallery__scroll-hint {
  display: none; flex: none; align-self: center;
  color: var(--fuul-brown); font-size: 24px; font-weight: 700;
  animation: pulse-hint 1.5s ease-in-out infinite;
  opacity: 0.6;
}
@keyframes pulse-hint {
  0%, 100% { opacity: 0.6; transform: translateX(0); }
  50% { opacity: 1; transform: translateX(4px); }
}

/* ---------- INFO ---------- */
.fuul-info { display: flex; flex-direction: column; align-items: flex-start; }

.fuul-head { display: flex; flex-direction: column; gap: 18px; margin-bottom: 28px; }
.fuul-rating { display: flex; align-items: center; gap: 12px; }
.fuul-rating img { display: block; width: 82px; height: auto; max-width: 100%; }
.fuul-rating__text { font-weight: 700; font-size: 28px; line-height: .8; letter-spacing: .2px; }

.fuul-title {
  font-family: var(--fuul-serif); font-weight: 600; font-size: 38px; line-height: 1.08;
  margin: 0; color: var(--fuul-brown); letter-spacing: -.3px;
}
.fuul-subtitle { font-size: 32px; line-height: .85; margin: 0; font-weight: 300; }
.fuul-subtitle strong { font-weight: 700; }

/* features */
.fuul-features { list-style: none; margin: 0 0 28px; padding: 0; display: flex; flex-direction: column; gap: 12px; }
.fuul-features__item { display: flex; align-items: center; gap: 18px; font-size: 32px; line-height: .8; }
.fuul-features__item img { display: block; flex: none; width: 32px; height: 32px; max-width: 100%; }

.fuul-divider { width: 100%; border: 0; border-top: 1.5px dashed rgba(96, 65, 63, .35); margin: 0 0 28px; }

.fuul-section-title { font-family: var(--fuul-sans); font-weight: 400; font-size: 42px; line-height: .8; margin: 0 0 18px; color: var(--fuul-brown); }

/* pills */
.fuul-pill {
  display: inline-flex; align-items: center; justify-content: center; gap: 4px;
  border-radius: 100px; padding: 8px 12px; font-weight: 700; font-size: 26px; line-height: .8;
  white-space: nowrap;
}
.fuul-pill--cream { background: var(--fuul-yellow-soft); color: var(--fuul-brown); }
.fuul-pill--gold { background: var(--fuul-yellow); color: var(--fuul-brown); }
.fuul-pill--serving { background: var(--fuul-green-soft); color: var(--fuul-green-dark); font-size: 18px; padding: 6px 10px; width: 100%; display: flex; align-items: center; gap: 4px; }
.fuul-pill--serving img { width: 13px; height: 13px; flex: none; }

/* ---------- BUNDLES ---------- */
.fuul-bundles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 13px; width: 100%; align-items: end; margin-bottom: 42px; padding-top: 14px; }
.fuul-bundle {
  position: relative; display: flex; flex-direction: column; align-items: center; gap: 12px;
  background: #fff; border: 1.5px solid var(--fuul-brown); border-radius: 8px;
  padding: 26px 20px; cursor: pointer; text-align: center; height: 100%; justify-content: flex-start;
}
.fuul-bundle__label { font-weight: 700; font-size: 36px; line-height: .8; }
.fuul-bundle__line { width: 100%; height: 0; border-top: 2px solid var(--fuul-brown); }
.fuul-bundle__sub { font-weight: 700; font-size: 24px; line-height: .8; }
.fuul-bundle__img { width: 120px; height: 120px; object-fit: contain; display: block; max-width: 100%; }
.fuul-bundle__price-group { display: flex; flex-direction: column; gap: 8px; }
.fuul-bundle__price { font-weight: 700; font-size: 36px; line-height: .8; }
.fuul-bundle__serving { display: flex; align-items: center; gap: 4px; font-size: 18px; font-weight: 400; color: var(--fuul-brown); }
.fuul-bundle__serving img { width: 13px; height: 13px; flex: none; }
.fuul-bundle__compare { font-weight: 300; font-size: 28px; line-height: .8; color: var(--fuul-brown-muted); text-decoration: line-through; }
.fuul-bundle--value { background: var(--fuul-cream); }
.fuul-bundle__badge {
  position: absolute; top: -15px; left: 50%; transform: translateX(-50%);
  border-radius: 100px; padding: 8px 14px; font-weight: 700; font-size: 26px; line-height: .8; white-space: nowrap; z-index: 2;
}
.fuul-bundle__badge--popular { background: var(--fuul-yellow); color: var(--fuul-brown); }
.fuul-bundle__badge--value { background: var(--fuul-green); color: #fff; }
/* selected: chunky offset border */
.fuul-bundle.is-selected { border-width: 2px 4px 4px 2px; }

/* ---------- AUTOSHIP PLANS ---------- */
.fuul-plans { display: flex; flex-direction: column; gap: 24px; width: 100%; margin-bottom: 24px; }
.fuul-plan {
  display: flex; flex-direction: column; gap: 18px; width: 100%;
  background: #fff; border: 1.5px solid #b3b3b3; border-radius: 14px; padding: 30px 28px; cursor: pointer;
}
.fuul-plan--sub.is-selected { border: 6px solid var(--fuul-gold); padding: 26px 24px; }
.fuul-plan__top { display: flex; align-items: center; gap: 18px; width: 100%; }
.fuul-radio {
  flex: none; width: 28px; height: 28px; border-radius: 50%;
  border: 1.5px solid #cfc4bd; background: #fff; position: relative;
}
.fuul-plan.is-selected .fuul-radio { border-color: var(--fuul-gold); }
.fuul-plan.is-selected .fuul-radio::after {
  content: ''; position: absolute; inset: 4px; border-radius: 50%; background: var(--fuul-gold);
}
.fuul-plan__info { display: flex; flex-direction: column; gap: 14px; }
.fuul-plan__name { font-weight: 700; font-size: 36px; line-height: .8; }
.fuul-plan__meta { font-weight: 300; font-size: 28px; line-height: .8; }
.fuul-plan__price { margin-left: auto; display: flex; flex-direction: column; align-items: flex-end; gap: 14px; text-align: right; }
.fuul-plan__now { font-weight: 700; font-size: 36px; line-height: .8; }
.fuul-plan__was { font-weight: 400; font-size: 28px; line-height: .8; color: var(--fuul-brown-muted); text-decoration: line-through; }
.fuul-plan__rule { width: 100%; border: 0; border-top: 1px solid #e7ddd7; margin: 0; }
.fuul-plan__perks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 18px; width: 100%; }
.fuul-plan__perks li { display: flex; align-items: center; gap: 8px; font-size: 32px; line-height: .8; font-weight: 400; }
.fuul-plan__perks li img { display: block; flex: none; width: 14px; height: auto; max-width: 100%; }
.fuul-plan__perks--muted li { font-weight: 300; color: rgba(96, 65, 63, .7); }

/* ---------- CTA ---------- */
.fuul-form { width: 100%; }
.fuul-cta {
  width: 100%; height: 72px; border: 0; border-radius: 100px; background: var(--fuul-brown);
  color: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--fuul-serif); font-weight: 600; font-size: 32px; line-height: 1; letter-spacing: .3px;
  transition: transform .08s ease, filter .15s ease; position: relative;
}
.fuul-cta:hover { filter: brightness(1.08); }
.fuul-cta:active { transform: translateY(1px); }
.fuul-cta[disabled] { opacity: .5; cursor: not-allowed; }

.fuul-promo {
  width: 100%; margin-top: 24px; background: var(--fuul-yellow-soft); color: var(--fuul-brown);
  border-radius: 14px; min-height: 52px; display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 32px; line-height: .8; text-align: center; padding: 12px 14px;
}
.fuul-promo p { margin: 0; }

/* ---------- TRUST ---------- */
.fuul-trust { width: 100%; display: grid; grid-template-columns: repeat(3, 1fr); gap: 34px; margin: 42px 0; }
.fuul-trust__item { display: flex; flex-direction: column; align-items: center; gap: 18px; text-align: center; }
.fuul-trust__item img { display: block; width: 52px; height: 52px; max-width: 100%; }
.fuul-trust__item span { font-size: 32px; line-height: .85; }

/* ---------- ACCORDIONS ---------- */
.fuul-accordions { width: 100%; display: flex; flex-direction: column; }
.fuul-acc { width: 100%; border-top: 1.5px dashed rgba(96, 65, 63, .35); }
.fuul-acc__summary {
  list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 28px 0; user-select: none;
}
.fuul-acc__summary::-webkit-details-marker { display: none; }
.fuul-acc__title { font-weight: 700; font-size: 36px; line-height: .8; }
.fuul-acc__icon {
  flex: none; width: 32px; height: 32px; border: 3px solid var(--fuul-brown); border-radius: 16px;
  display: inline-flex; align-items: center; justify-content: center; transition: transform .2s ease;
}
.fuul-acc__icon img { display: block; width: 13px; height: 13px; max-width: 100%; }
.fuul-acc[open] .fuul-acc__icon { transform: rotate(45deg); }
.fuul-acc__body { padding: 0 0 28px; font-size: 30px; line-height: 1; }
.fuul-acc__body p { margin: 0 0 .5em; }

/* ---------- RESPONSIVE ---------- */
@media (max-width: 1100px) {
  .fuul-pdp__inner { grid-template-columns: minmax(0, 1fr); gap: 40px; padding: 32px 20px 60px; }
  .fuul-gallery { position: static; max-width: 560px; margin: 0 auto; width: 100%; }
  .fuul-info { max-width: 560px; margin: 0 auto; width: 100%; }
}
@media (max-width: 560px) {
  .fuul-gallery { grid-template-columns: minmax(0, 1fr); }
  .fuul-gallery__thumbs {
    order: 2; flex-direction: row; overflow-x: auto; gap: 8px;
    /* Smooth scrolling and scroll snap */
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    padding-bottom: 8px;
    /* Hide scrollbar for cleaner look */
    -ms-overflow-style: none;
    scrollbar-width: none;
    align-items: center;
  }
  .fuul-gallery__thumbs::-webkit-scrollbar { display: none; }
  .fuul-gallery__thumb {
    width: 59px; scroll-snap-align: center;
    /* Prevent overly eager vertical scrolling */
    flex-shrink: 0;
  }
  .fuul-gallery__scroll-hint { display: flex; }
  .fuul-gallery__main { order: 1; border-radius: 16px; }
  .fuul-title { font-size: 30px; }

  /* Icon responsiveness on mobile */
  .fuul-rating img { width: 56px; }
  .fuul-features__item { gap: 12px; font-size: 20px; }
  .fuul-features__item img { width: 22px; height: 22px; }

  /* bundles become full-width rows on mobile */
  .fuul-bundles { grid-template-columns: minmax(0, 1fr); gap: 22px; }
  .fuul-bundle {
    flex-direction: row; align-items: center; justify-content: flex-start; gap: 14px;
    text-align: left; padding: 12px 14px; height: auto;
  }
  .fuul-bundle__img { order: -1; width: 64px; height: 64px; }
  .fuul-bundle__line { display: none; }
  .fuul-bundle__label { font-size: 22px; }
  .fuul-bundle__price-group { margin-left: auto; gap: 4px; }
  .fuul-bundle__price { font-size: 22px; }
  .fuul-bundle__serving { font-size: 12px; }
  .fuul-bundle__serving img { width: 9px; height: 9px; }
  .fuul-bundle__compare { margin-left: auto; }
  .fuul-bundle__badge { left: 14px; transform: none; }

  .fuul-plan__name { font-size: 24px; }
  .fuul-plan__perks li { font-size: 20px; }
  .fuul-plan__perks li img { width: 10px; }
  .fuul-trust { gap: 20px; margin: 28px 0; }
  .fuul-trust__item img { width: 40px; height: 40px; }
  .fuul-trust__item span { font-size: 20px; }

  /* Accordion caret resize on mobile */
  .fuul-acc__icon { width: 24px; height: 24px; }
  .fuul-acc__icon img { width: 10px; height: 10px; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  function initFuul(root) {
    if (!root || root.__fuulInit) return;
    root.__fuulInit = true;

    var quantityInput = root.querySelector('[data-fuul-quantity]');
    var sellingPlanInput = root.querySelector('[data-fuul-selling-plan]');

    // Plan prices are pre-rendered by Liquid for every bundle quantity, so the
    // displayed figures stay Shopify-formatted (currency, delimiters) without
    // doing any money math in JS.
    function syncPlanPrices(quantity) {
      root.querySelectorAll('[data-fuul-plan-price], [data-fuul-plan-compare], [data-fuul-once-price]').forEach(
        function (el) {
          var next = el.getAttribute('data-price-' + quantity);
          if (next) el.textContent = next;
        }
      );
    }

    // Bundle selection -> quantity
    var bundles = root.querySelectorAll('[data-fuul-bundle]');
    bundles.forEach(function (el) {
      el.addEventListener('click', function () {
        bundles.forEach(function (b) { b.classList.remove('is-selected'); });
        el.classList.add('is-selected');
        var input = el.querySelector('input[type="radio"]');
        if (input) input.checked = true;
        var quantity = el.getAttribute('data-quantity') || '1';
        if (quantityInput) quantityInput.value = quantity;
        syncPlanPrices(quantity);
      });
    });

    // Keep the form and the plan prices in step with the pre-selected bundle.
    var initialBundle = root.querySelector('[data-fuul-bundle].is-selected') || bundles[0];
    if (initialBundle) {
      var initialQuantity = initialBundle.getAttribute('data-quantity') || '1';
      if (quantityInput) quantityInput.value = initialQuantity;
      syncPlanPrices(initialQuantity);
    }

    // Plan selection -> selling_plan
    var plans = root.querySelectorAll('[data-fuul-plan]');
    plans.forEach(function (el) {
      el.addEventListener('click', function () {
        plans.forEach(function (p) { p.classList.remove('is-selected'); });
        el.classList.add('is-selected');
        var input = el.querySelector('input[type="radio"]');
        if (input) input.checked = true;
        if (sellingPlanInput) sellingPlanInput.value = el.getAttribute('data-selling-plan') || '';
      });
    });

    // Gallery thumbnails
    var gallery = root.querySelector('[data-fuul-gallery]');
    if (gallery) {
      var main = gallery.querySelector('[data-fuul-main]');
      var scrollContainer = gallery.querySelector('[data-fuul-scroll-container]');
      var scrollHint = gallery.querySelector('.fuul-gallery__scroll-hint');

      gallery.querySelectorAll('[data-fuul-thumb]').forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          gallery.querySelectorAll('[data-fuul-thumb]').forEach(function (t) { t.classList.remove('is-active'); });
          thumb.classList.add('is-active');
          var src = thumb.getAttribute('data-src');
          if (main && src) main.src = src;
        });
      });

      // Hide scroll hint when scrolling
      if (scrollContainer && scrollHint) {
        scrollContainer.addEventListener('scroll', function () {
          scrollHint.style.opacity = '0';
          clearTimeout(scrollContainer.__hintTimeout);
          scrollContainer.__hintTimeout = setTimeout(function () {
            if (scrollContainer.scrollLeft < 10) scrollHint.style.opacity = '';
          }, 3000);
        });
      }
    }
  }

  function run() {
    document.querySelectorAll('.fuul-pdp').forEach(initFuul);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
  // Re-init on theme editor section load
  document.addEventListener('shopify:section:load', run);
})();
{% endjavascript %}

{% schema %}
{
  "name": "FUUL Product Page",
  "tag": "section",
  "class": "section-fuul-pdp",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9/5 | 20,000+ Customers" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Each bag contains half a pound of delicious cookie dough bites packed with protein." },
    { "type": "textarea", "id": "features", "label": "Feature list (one per line)", "default": "40g Protein Per Bag\nNo Seed Oils\nReal Cookie Dough Taste\nSoft and Chewy" },
    { "type": "header", "content": "Bundle selector" },
    { "type": "paragraph", "content": "Prices, compare-at prices and savings are read from the product in Shopify. To discount the multi-unit tiers, set up volume pricing (quantity price breaks) on the variant — those prices are honoured at checkout." },
    { "type": "text", "id": "bundle_heading", "label": "Heading", "default": "How many bags?" },
    { "type": "text", "id": "b1_label", "label": "Bundle 1 label", "default": "1 Bag" },
    { "type": "number", "id": "b1_quantity", "label": "Bundle 1 quantity", "default": 1 },
    { "type": "text", "id": "b2_badge", "label": "Bundle 2 badge", "default": "Most Popular" },
    { "type": "text", "id": "b2_label", "label": "Bundle 2 label", "default": "2 Bags" },
    { "type": "number", "id": "b2_quantity", "label": "Bundle 2 quantity", "default": 2 },
    { "type": "text", "id": "b3_badge", "label": "Bundle 3 badge", "default": "Best Value" },
    { "type": "text", "id": "b3_label", "label": "Bundle 3 label", "default": "4 Bags" },
    { "type": "text", "id": "b3_sublabel", "label": "Bundle 3 sublabel", "default": "Buy 3 Get 1 FREE" },
    { "type": "number", "id": "b3_quantity", "label": "Bundle 3 quantity", "default": 4 },
    { "type": "number", "id": "servings_per_unit", "label": "Servings per unit", "info": "Used to work out the per-serving price. Leave at 0 to hide it.", "default": 0 },
    { "type": "text", "id": "serving_suffix", "label": "Per-serving suffix", "default": "per serving" },
    { "type": "header", "content": "Autoship & Save" },
    { "type": "text", "id": "autoship_heading", "label": "Heading", "default": "Autoship & Save" },
    { "type": "text", "id": "sub_title", "label": "Subscribe title", "default": "Subscribe & Save" },
    { "type": "text", "id": "sub_billing", "label": "Subscribe billing fallback", "info": "Only used when the product has no selling plan — otherwise the plan's own name is shown.", "default": "Billed every 12 weeks" },
    { "type": "textarea", "id": "sub_perks", "label": "Subscribe perks (one per line)", "default": "Save On Every Order\nAutomatic Delivery\nPause, Skip, or Cancel Any Time" },
    { "type": "text", "id": "once_title", "label": "One-time title", "default": "One Time Purchase" },
    { "type": "text", "id": "once_billing", "label": "One-time billing", "default": "Billed once" },
    { "type": "textarea", "id": "once_perks", "label": "One-time notes (one per line)", "default": "No subscription discount\nNo automatic delivery" },
    { "type": "header", "content": "Add to cart" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Add To Cart" },
    { "type": "richtext", "id": "promo_bar", "label": "Promo bar", "default": "<p>Limited Time Discount Auto-Applied ✅</p>" },
    { "type": "header", "content": "Trust badges" },
    { "type": "text", "id": "trust1", "label": "Badge 1", "default": "Ships Within 1 Business Day" },
    { "type": "text", "id": "trust2", "label": "Badge 2", "default": "Free Shipping Over $65" },
    { "type": "text", "id": "trust3", "label": "Badge 3", "default": "Secure Checkout" },
    { "type": "header", "content": "Accordions" },
    { "type": "text", "id": "acc1_heading", "label": "Accordion 1 heading", "default": "Ingredients" },
    { "type": "richtext", "id": "acc1_body", "label": "Accordion 1 body", "default": "<p>Add your ingredients here.</p>" },
    { "type": "text", "id": "acc2_heading", "label": "Accordion 2 heading", "default": "Nutrition Facts" },
    { "type": "richtext", "id": "acc2_body", "label": "Accordion 2 body", "default": "<p>Add your nutrition facts here.</p>" },
    { "type": "text", "id": "acc3_heading", "label": "Accordion 3 heading", "default": "How to Store" },
    { "type": "richtext", "id": "acc3_body", "label": "Accordion 3 body", "default": "<p>Add storage instructions here.</p>" }
  ],
  "presets": [
    { "name": "FUUL Product Page" }
  ]
